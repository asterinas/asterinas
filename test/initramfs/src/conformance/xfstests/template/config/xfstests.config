# SPDX-License-Identifier: MPL-2.0

# Filesystem type under test.
export FSTYP=template

# Block devices for the test and scratch partitions.
# For block-based filesystems, these are typically virtio-blk device paths.
# For pseudo filesystems (e.g., tmpfs), these can be arbitrary identifiers.
export TEST_DEV=
export SCRATCH_DEV=

# Mount points where test and scratch devices will be mounted.
export TEST_DIR=/opt/xfstests/test
export SCRATCH_MNT=/opt/xfstests/scratch

# Mount options applied to test and scratch filesystems respectively.
export MOUNT_OPTIONS=""
export EXT_MOUNT_OPTIONS=""

# Set to 1 if the filesystem uses non-default mount options that affect behavior.
export FSTYP_HAS_NON_DEFAULT_OPTS=0
# SELinux-related mount options. A single space effectively disables SELinux context.
export SELINUX_MOUNT_OPTIONS=" "

# Options passed to mkfs when formatting test/scratch devices.
export MKFS_OPTIONS=""
