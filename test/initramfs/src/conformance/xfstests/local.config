if [ "${XFSTESTS_BACKEND:-block}" = "virtiofs" ]; then
    export FSTYP=virtiofs
    export MOUNT_OPTIONS=""
    export MKFS_OPTIONS=""
else
    export FSTYP=ext2
    export MOUNT_OPTIONS="-o noacl"
    export EXT_MOUNT_OPTIONS="-o noacl"
    export MKFS_OPTIONS="-F"
fi

# TEST_DEV and SCRATCH_DEV are set by run_xfstests.sh from
# the selected xfstests backend.

export TEST_DIR=/opt/xfstests/test
export SCRATCH_MNT=/opt/xfstests/scratch

export FSTYP_HAS_NON_DEFAULT_OPTS=0
export SELINUX_MOUNT_OPTIONS=" "
