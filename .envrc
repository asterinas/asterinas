# SPDX-License-Identifier: MPL-2.0

# The dev shell is defined under nix/, but neither direnv's own `use flake`
# nor nix-direnv's replacement for it watches anything beyond flake.nix and
# flake.lock. Watch the other inputs explicitly, or editing them leaves
# direnv serving the shell it cached last time.
watch_file rust-toolchain.toml
watch_dir nix

use flake
