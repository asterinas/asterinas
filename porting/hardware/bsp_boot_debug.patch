+
+# Tiny physical-mode trap handler: prints 'T' followed by the low nibble
+# of scause in hex, then spins.  This lets us see the first exception
+# even if the normal exception path is not yet set up.
+.balign 4
+_early_trap:
+    csrr t0, scause
+    andi t0, t0, 0x7f
+    li t3, 0x50900000
+    li t4, 'T'
+    sb t4, 0(t3)
+    andi t4, t0, 0xf
+    li t5, 9
+    ble t4, t5, 1f
+    addi t4, t4, 'a' - 10
+    j 2f
+1:
+    addi t4, t4, '0'
+2:
+    sb t4, 0(t3)
+3:
+    j 3b
