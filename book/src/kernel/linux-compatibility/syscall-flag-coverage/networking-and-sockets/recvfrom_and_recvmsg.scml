// Supported message receive flags
recv_flags = MSG_PEEK | MSG_TRUNC;

// Receive message from a socket
recvfrom(
    sockfd, buf, size,
    flags = <recv_flags>,
    src_addr, addrlen
);

// Receive message using scatter-gather buffers and ancillary data
recvmsg(
    sockfd,
    msg,
    flags = <recv_flags>
);
